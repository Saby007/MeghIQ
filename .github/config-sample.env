# Sample Environment Configuration for PR Review Workflow
# Copy this file to use as a reference for setting up GitHub Secrets

# ===== AUTHENTICATION OPTIONS =====

# Option 1: API Key Authentication (RECOMMENDED - Simpler setup)
AZURE_OPENAI_API_KEY=your-api-key-here

# Option 2: Service Principal Authentication (Advanced - More secure)
# AZURE_CREDENTIALS (JSON format - from service principal creation)
# AZURE_CREDENTIALS='{
#   "clientId": "your-client-id-here",
#   "clientSecret": "your-client-secret-here", 
#   "subscriptionId": "your-subscription-id-here",
#   "tenantId": "your-tenant-id-here",
#   "activeDirectoryEndpointUrl": "https://login.microsoftonline.com",
#   "resourceManagerEndpointUrl": "https://management.azure.com/",
#   "activeDirectoryGraphResourceId": "https://graph.windows.net/",
#   "sqlManagementEndpointUrl": "https://management.core.windows.net:8443/",
#   "galleryEndpointUrl": "https://gallery.azure.com/",
#   "managementEndpointUrl": "https://management.core.windows.net/"
# }'

# ===== REQUIRED SECRETS =====

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ===== OPTIONAL SECRETS =====

# Review Configuration (Optional - has sensible defaults)
MAX_REVIEW_TOKENS=2000
REVIEW_TEMPERATURE=0.3

# ===== WORKFLOW CUSTOMIZATION =====
# These are set directly in the workflow file, not as secrets

# Branches to review (edit in workflow YAML)
TARGET_BRANCHES=main,develop

# File extensions to review
CODE_EXTENSIONS=.py,.js,.ts,.java,.cpp,.c,.cs,.php,.rb,.go,.rs,.kt,.swift

# Maximum files to review in a single PR
MAX_FILES_LIMIT=50

# Skip PR review if title contains these prefixes
SKIP_PREFIXES=[SKIP-REVIEW],[WIP],[DRAFT]