# Environment configuration
ENVIRONMENT=development
PORT=8000

# Azure OpenAI Configuration (Option 1 - Recommended)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-api-key  # Leave empty to use Managed Identity
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Authentication Method:
# - Leave AZURE_OPENAI_API_KEY empty to use Managed Identity (Azure Web App, VM with MSI)
# - Set AZURE_OPENAI_API_KEY for local development with API key

# OR OpenAI Configuration (Option 2 - Development)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
