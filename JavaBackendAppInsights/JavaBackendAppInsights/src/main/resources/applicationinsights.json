{
  "connectionString": "${APPLICATIONINSIGHTS_CONNECTION_STRING}",
  "role": {
    "name": "monitoring-demo-api"
  },
  "sampling": {
    "percentage": 100
  },
  "instrumentation": {
    "logging": {
      "level": "INFO"
    },
    "micrometer": {
      "enabled": true
    },
    "jdbc": {
      "enabled": true
    },
    "redis": {
      "enabled": true
    },
    "springScheduling": {
      "enabled": true
    }
  },
  "preview": {
    "processors": [
      {
        "type": "attribute",
        "include": {
          "matchType": "strict",
          "spanNames": [
            "HTTP GET"
          ]
        },
        "actions": [
          {
            "key": "environment",
            "value": "development",
            "action": "insert"
          }
        ]
      }
    ]
  }
}