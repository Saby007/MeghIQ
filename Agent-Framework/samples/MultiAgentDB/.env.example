# Azure OpenAI Configuration
# Copy this file to .env and update with your actual values

# Azure OpenAI Endpoint - Get from Azure Portal > Your OpenAI Resource > Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Chat Deployment Name - Get from Azure Portal > Your OpenAI Resource > Model deployments
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4

# API Version - Use the latest available version
AZURE_OPENAI_API_VERSION=2024-02-01

# Optional: If using API key authentication instead of managed identity (not recommended for production)
# AZURE_OPENAI_API_KEY=your_api_key_here