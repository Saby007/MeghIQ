# Azure OpenAI Configuration
# Replace with your actual Azure OpenAI resource values

# Your Azure OpenAI endpoint (e.g., https://your-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# API version (use the latest supported version)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Your deployment name (the name you gave to your model deployment)
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Optional: Additional configuration
# AZURE_OPENAI_TEMPERATURE=0.1
# AZURE_OPENAI_MAX_TOKENS=1000
# AZURE_OPENAI_TOP_P=0.95