# ── Project-specific generated artefacts ─────────────────────────────
# PDF reports written by tools/pdf_report.py default to a temp dir, but
# in case anyone runs with --out-dir . we ignore them in the tree.
*.pdf

# Azure Updates CSV dumps generated by update_intelligence.py
azure_updates_*.csv
!mcp-server/azure_updates_report.csv

# Pip-audit / bandit machine-readable reports
pip-audit.json
bandit-report.json

# Local logs
*.log
logs/
